.user-info {
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 24rpx;
}

.user-text {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 28rpx;
  color: #666666;
}

.action-buttons {
  margin-bottom: 32rpx;
}

.menu-list {
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.favorites-icon {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
}

.history-icon {
  background: linear-gradient(135deg, #4834d4, #686de0);
}

.settings-icon {
  background: linear-gradient(135deg, #576574, #8395a7);
}

.about-icon {
  background: linear-gradient(135deg, #22a6b3, #3498db);
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  border-right: 3rpx solid #cccccc;
  border-bottom: 3rpx solid #cccccc;
  transform: rotate(-45deg);
}

.app-info {
  text-align: center;
  padding: 40rpx 0;
}

.app-version {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.app-copyright {
  font-size: 24rpx;
  color: #999999;
}