<view class="container">
  <view class="user-info">
    <view wx:if="{{isLoggedIn}}" class="user-details">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-text">
        <text class="username">{{userInfo.nickName}}</text>
        <text class="user-desc">欢迎回来！</text>
      </view>
    </view>
    <view wx:else class="login-prompt">
      <view class="avatar-placeholder"></view>
      <view class="user-text">
        <text class="username">未登录</text>
        <text class="user-desc">登录后享受更多功能</text>
      </view>
    </view>
  </view>

  <view class="action-buttons">
    <view wx:if="{{!isLoggedIn}}" class="btn-primary" bindtap="login">登录</view>
    <view wx:if="{{isLoggedIn}}" class="btn-secondary" bindtap="logout">退出登录</view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="showFavorites">
      <view class="menu-icon favorites-icon"></view>
      <text class="menu-text">我的收藏</text>
      <view class="menu-arrow"></view>
    </view>
    
    <view class="menu-item" bindtap="showHistory">
      <view class="menu-icon history-icon"></view>
      <text class="menu-text">浏览历史</text>
      <view class="menu-arrow"></view>
    </view>
    
    <view class="menu-item" bindtap="showSettings">
      <view class="menu-icon settings-icon"></view>
      <text class="menu-text">设置</text>
      <view class="menu-arrow"></view>
    </view>
    
    <view class="menu-item" bindtap="showAbout">
      <view class="menu-icon about-icon"></view>
      <text class="menu-text">关于我们</text>
      <view class="menu-arrow"></view>
    </view>
  </view>

  <view class="app-info">
    <text class="app-version">版本 1.0.0</text>
    <text class="app-copyright">© 2026 VR“云”游花桥村</text>
  </view>
</view>