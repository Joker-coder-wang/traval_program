.search-box {
  padding: 20rpx;
  width: 100%;
  background-color: #fff;
  position: relative;
  z-index: 10;
}

.search-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 0;
  background-color: #fff;
  border-radius: 10rpx;
}
.search-img {
  width: 45rpx;
  height: 45rpx;
  background-color: #fff;
}
.search-ipt {
  width: 650rpx;
  background-color: #fff;
  padding: 10rpx 20rpx;
}

swiper{
  height:420rpx;
}
swiper image{
  width: 100%;
  height: 100%;
}
.header {
  text-align: center;
  padding: 0rpx 0;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1890ff;
  display: block;
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #666666;
}

.card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.vr-icon {
  background: linear-gradient(135deg, #1890ff, #52c41a);
}

.info-icon {
  background: linear-gradient(135deg, #faad14, #fadb14);
}

.route-icon {
  background: linear-gradient(135deg, #f5222d, #fa541c);
}

.card-content {
  flex: 1;
}

.card-arrow {
  width: 24rpx;
  height: 24rpx;
  border-right: 3rpx solid #cccccc;
  border-bottom: 3rpx solid #cccccc;
  transform: rotate(-45deg);
}

.featured-attractions {
  margin-top: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  display: block;
}

.attraction-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.attraction-item {
  width: 48%;
  margin-bottom: 24rpx;
  background-color: white;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.attraction-image {
  width: 100%;
  height: 240rpx;
}

.attraction-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  padding: 16rpx;
  display: block;
}

.attraction-location {
  font-size: 24rpx;
  color: #999999;
  padding: 0 16rpx 16rpx;
  display: block;
}