.vr-container {
  position: relative;
  height: 500rpx;
  margin-bottom: 24rpx;
}

.divider {
  border-top: 2rpx solid #e5e5e5;
  margin: 24rpx 0;
}

.vr-swiper {
  width: 100%;
  height: 100%;
}

.vr-image {
  width: 100%;
  height: 100%;
}

.vr-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 40rpx 24rpx 24rpx;
}

.vr-title {
  color: white;
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.vr-controls {
  display: flex;
  justify-content: space-between;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-icon {
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

.attraction-info {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.route-section {
  margin-top: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  display: block;
}

.route-item {
  display: flex;
  margin-bottom: 24rpx;
}

.route-step {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #1890ff;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.route-description {
  flex: 1;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-buttons .btn-primary,
.action-buttons .btn-secondary {
  flex: 1;
}