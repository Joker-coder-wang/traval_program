page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background-color: #1890ff;
  color: white;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666666;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 12rpx;
}

.text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

.image {
  width: 100%;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}